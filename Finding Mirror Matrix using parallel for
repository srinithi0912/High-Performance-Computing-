#include<stdio.h>
#include<stdlib.h>
#include<omp.h>

int main(){
   int rows,cols,i,j,k;
   printf("**** To find the mirror matrix using parallel for  ****\n");
   printf("Enter the rows and columns in matrix:");
   scanf("%d %d",&rows,&cols);

   int mat1[rows][cols],mat2[rows][cols],res[rows][cols];

   printf("Generated Matrix 1:\n\n");
   for(i=0;i<rows;i++){
      for(j=0;j<cols;j++){
         mat1[i][j] = (rand()%10)+1;
      }
   }
   for(i=0;i<rows;i++){
      for(j=0;j<cols;j++){
         printf("%d ",mat1[i][j]);
      }
      printf("\n");
   }
   printf("\n\n");

# pragma omp parallel for
   for(i=0;i<rows;i++){
      k = 0;
      for(j=cols-1;j>=0;j--){
         res[i][k] = mat1[i][j];
         k++;
      }
   }

   printf("*** Resultant Array ***\n\n");
   for(i=0;i<rows;i++){
      for(j=0;j<cols;j++){
        printf("%d ",res[i][j]);
      }
      printf("\n");
   }
   printf("\n");
   return 0;
}
