#include<stdio.h>
#include<stdlib.h>
#include<mpi.h>
#include<time.h>

int main(){
    int rank,size;
    int N,i;
    int target;
    int *array=NULL;
    int *sub_array;
    int local_count=0,total_count=0;
    MPI_Init(NULL,NULL);
    MPI_Comm_rank(MPI_COMM_WORLD,&rank);
    MPI_Comm_size(MPI_COMM_WORLD,&size);

    if(rank == 0){
       printf("Enter the Number of elements:");
       fflush(stdout);
       scanf("%d",&N);
       printf("Enter the Number to find the Frequency:");
       fflush(stdout);
       scanf("%d",&target);
    }
    MPI_Bcast(&N,1,MPI_INT,0,MPI_COMM_WORLD);
    MPI_Bcast(&target,1,MPI_INT,0,MPI_COMM_WORLD);
    int chunk = N/size;

    sub_array = (int*)malloc(chunk*sizeof(int));
    if(rank == 0){
       array = (int*)malloc(N*sizeof(int));
       printf("Generated Array:");
       for(i=0;i<N;i++){
           array[i] = rand()%10;
           printf("%d ",array[i]);
       }
       printf("\n");
    }

    MPI_Scatter(array,chunk,MPI_INT,sub_array,chunk,MPI_INT,0,MPI_COMM_WORLD);
    for(i=0;i<chunk;i++){
        if(sub_array[i]==target){
           local_count++;
        }
    }

    MPI_Reduce(&local_count,&total_count,1,MPI_INT,MPI_SUM,0,MPI_COMM_WORLD);
    if(rank == 0){
       printf("Frequency of %d is %d\n",target,total_count);
    }
    free(sub_array);
    if(rank == 0){
         free(array);
    }
    MPI_Finalize();
    return 0;
}
