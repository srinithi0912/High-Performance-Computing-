#include<stdio.h>
#include<stdlib.h>
#include<pthread.h>

int thread_count;
void* Hello(void* rank);

int main(int argc,char* argv[]){
   long thread;
   pthread_t* thread_handler;
   thread_count = strtol(argv[1],NULL,10);
   thread_handler = malloc(thread_count*sizeof(pthread_t));

   printf("\n**** Printing the hello message from each thread! ****\n\n");

   for(thread=0;thread<thread_count;thread++){
      pthread_create(&thread_handler[thread],NULL,Hello,(void*) thread);
   }

   for(thread=0;thread<thread_count;thread++){
      pthread_join(thread_handler[thread],NULL);
   }

   printf("Hello from the main thread!\n\n");

   free(thread_handler);
   return 0;
}

void* Hello(void* rank){
   long my_rank = (long)rank;
   printf("Hello from thread:%ld of %d\n\n",my_rank,thread_count);
}
