#include <stdio.h>
#include <stdlib.h>
#include <sys/time.h>

int main() {
    int m, n, p;
    printf("Enter the matrix dimension (m n p): ");
    if (scanf("%d %d %d", &m, &n, &p) != 3) return 1;


    int **A = (int **)malloc(m * sizeof(int *));
    int **B = (int **)malloc(n * sizeof(int *));
    int **C = (int **)malloc(m * sizeof(int *));
    for (int i = 0; i < m; i++) {
        A[i] = (int *)malloc(n * sizeof(int));
        C[i] = (int *)malloc(p * sizeof(int));
    }
    for (int i = 0; i < n; i++)
        B[i] = (int *)malloc(p * sizeof(int));


    for (int i = 0; i < m; i++)
        for (int j = 0; j < n; j++)
            A[i][j] = rand() % 10;
    for (int i = 0; i < n; i++)
        for (int j = 0; j < p; j++)
            B[i][j] = rand() % 10;


    struct timeval start, end;
    gettimeofday(&start, NULL);


    for (int i = 0; i < m; i++) {
        for (int j = 0; j < p; j++) {
            C[i][j] = 0;
            for (int k = 0; k < n; k++)
                C[i][j] += A[i][k] * B[k][j];
        }
    }

    gettimeofday(&end, NULL);
    //printf("Matrix A\n");
    if(m<=10&&n<=10){
       printf("\n***** Matrix A *****\n");
       for(int i=0;i<m;i++){
          for(int j=0;j<n;j++){
             printf("%d\t",A[i][j]);
          }
          printf("\n");
       }
    }
   // printf("\nMatrix B\n");
    if(n<=10&&p<=10){
       printf("\n***** Matrix B *****\n");
       for(int i=0;i<n;i++){
          for(int j=0;j<p;j++){
             printf("%d\t",B[i][j]);
          }
          printf("\n");
       }
    }
    //printf("\n*Result\n");

    if(m<=10&&p<=10){
       //int z=0;
       printf("\n***** Result *****\n");
       for(int i=0;i<m;i++){
          for(int j=0;j<p;j++){
             printf("%d\t",C[i][j]);
          }
          printf("\n");
       }
       printf("\n");
    }

    double time_spent_ms = (double)(end.tv_sec - start.tv_sec) * 1000.0 +
                           (double)(end.tv_usec - start.tv_usec) / 1000.0;

    printf("Serial Time: %f milliseconds\n", time_spent_ms);


    for (int i = 0; i < m; i++) {
        free(A[i]);
        free(C[i]);
    }
    for (int i = 0; i < n; i++) {
        free(B[i]);
    }
    free(A);
    free(B);
    free(C);

    return 0;
}
