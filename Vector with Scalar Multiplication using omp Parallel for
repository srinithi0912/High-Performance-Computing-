#include<stdio.h>
#include<stdlib.h>
#include<omp.h>

int main(){
   int *arr;
   int size,scalar_const,i;
   arr = (int*)malloc(size*sizeof(int));

   printf("Enter the size of the array:");
   scanf("%d",&size);
   printf("Enter the scalar constant:");
   scanf("%d",&scalar_const);
   printf("\n");

   printf("[");
   for(i =0;i<size;i++){
      arr[i] = (rand() % 10)+1;
      printf("%d ",arr[i]);
   }
   printf("]\n");
   int thread_count = size/2;

#pragma omp parallel for num_threads(thread_count)

   for(i=0;i<size;i++){
      arr[i] = arr[i] + scalar_const;
   }

   printf("\n*** Resultant Array ***\n\n[");
   for(i=0;i<size;i++){
      printf("%d ",arr[i]);
   }
   printf("]\n\n");
   return 0;
}
